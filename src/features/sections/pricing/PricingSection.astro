---
import { useT } from "~/shared/i18n/fn";
import type { TranslationKey } from "~/shared/i18n/types";
const t = useT(Astro.currentLocale);
type Pricing = {
  oldPrice?: number;
  price?: number;
  title: TranslationKey;
  description: TranslationKey;
  features: TranslationKey[];
  cta: TranslationKey;
};
const pricingPacks: Pricing[] = [
  {
    oldPrice: 1499,
    price: 699,
    title: "pack_1_title",
    description: "pack_1_description",
    features: [
      "pack_1_feature_1",
      "pack_1_feature_2",
      "pack_1_feature_3",
      "pack_1_feature_4",
      "pack_1_feature_5",
    ],
    cta: "pack_1_cta",
  },
  {
    oldPrice: 799,
    price: 499,
    title: "pack_2_title",
    description: "pack_2_description",
    features: [
      "pack_2_feature_1",
      "pack_2_feature_2",
      "pack_2_feature_3",
      "pack_2_feature_4",
      "pack_2_feature_5",
    ],
    cta: "pack_2_cta",
  },
  {
    title: "pack_3_title",
    description: "pack_3_description",
    features: [
      "pack_3_feature_1",
      "pack_3_feature_2",
      "pack_3_feature_3",
      "pack_3_feature_4",
      "pack_3_feature_5",
    ],
    cta: "pack_3_cta",
  },
];

function urlMaker(title: string) {
  return `/proposal?pricing=${encodeURIComponent(title)}`;
}
---

<section class="flex flex-col gap-8 py-20">
  <header class="flex flex-col gap-4">
    <h2 class="text-xl md:text-3xl font-bold">{t("prices")}</h2>
  </header>
  <ul
    class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 md:gap-6 font-light"
  >
    {
      pricingPacks.map((pricing, index) => (
        <li
          class:list={[
            "grid relative bg-muted rounded-lg overflow-hidden p-6 last:bg-linear-30 last:bg-gradient-to-r last:from-primary/20 last:to-secondary/10",
            {
              "grid-rows-[auto_1fr_auto]": pricing.oldPrice || pricing.price,
              "grid-rows-[1fr_auto]": !pricing.oldPrice && !pricing.price,
            },
          ]}
        >
          {index === 1 && (
            <div class="absolute top-0 right-0 bg-primary text-xs font-bold px-3 py-2 rounded-bl-xl">
              {t("popular")}
            </div>
          )}

          {(pricing.oldPrice || pricing.price) && (
            <header class="flex flex-col pb-4">
              {pricing.oldPrice && (
                <span class="line-through text-sm text-muted-foreground">
                  {pricing.oldPrice}€
                </span>
              )}
              {pricing.price && <span class="text-lg">{pricing.price}€</span>}
            </header>
          )}
          <div class="flex flex-col gap-4 pb-8">
            <h3 class="text-xl">{t(pricing.title)}</h3>
            <p class="text-muted-foreground font-thin text-normal text-[1em]">
              {t(pricing.description)}
            </p>
            <ul class="flex flex-col list-disc gap-2 pt-7  border-t border-muted-foreground/20">
              {pricing.features.map((feature) => (
                <li class="flex items-center gap-2 text-sm">
                  <span>&#10003;</span>
                  <span>{t(feature)}</span>
                </li>
              ))}
            </ul>
          </div>
          <footer class="flex gap-2 items-center">
            <a
              href={urlMaker(pricing.title)}
              class="w-fit rounded-full bg-foreground px-4 py-2 text-background font-semibold hover:bg-primary-700 transition-colors cursor-pointer"
            >
              {t(pricing.cta)}
            </a>
          </footer>
        </li>
      ))
    }
  </ul>
</section>
