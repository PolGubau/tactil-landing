---
import { useT } from "~/shared/i18n/fn";
import type { TranslationKey } from "~/shared/i18n/types";
const t = useT(Astro.currentLocale);
type Pricing = {
  id: string;
  oldPrice?: number;
  price?: number;
  title: TranslationKey;
  description: TranslationKey;
  features: TranslationKey[];
  cta: TranslationKey;
};
const pricingPacks: Pricing[] = [
  {
    id: "corporate",
    oldPrice: 1499,
    price: 699,
    title: "pack_1_title",
    description: "pack_1_description",
    features: [
      "pack_1_feature_1",
      "pack_1_feature_2",
      "pack_1_feature_3",
      "pack_1_feature_4",
      "pack_1_feature_5",
    ],
    cta: "pack_1_cta",
  },
  {
    id: "landing",
    oldPrice: 799,
    price: 499,
    title: "pack_2_title",
    description: "pack_2_description",
    features: [
      "pack_2_feature_1",
      "pack_2_feature_2",
      "pack_2_feature_3",
      "pack_2_feature_4",
      "pack_2_feature_5",
    ],
    cta: "pack_2_cta",
  },
  {
    id: "custom",
    title: "pack_3_title",
    description: "pack_3_description",
    features: [
      "pack_3_feature_1",
      "pack_3_feature_2",
      "pack_3_feature_3",
      "pack_3_feature_4",
      "pack_3_feature_5",
    ],
    cta: "pack_3_cta",
  },
];
---

<section id="pricing" class="flex flex-col gap-12 py-24 px-4">
  <header class="flex flex-col gap-4 text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight">
      {t("prices")}
    </h2>
    <p class="text-base md:text-lg text-muted-foreground max-w-2xl mx-auto">
      {t("prices_subtitle")}
    </p>
  </header>
  <ul
    class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8 max-w-7xl mx-auto w-full"
  >
    {
      pricingPacks.map((pricing, index) => (
        <li
          class:list={[
            "grid relative bg-background border border-border rounded-2xl overflow-hidden p-8 hover:shadow-xl transition-all duration-300",
            {
              "grid-rows-[auto_1fr_auto]": pricing.oldPrice || pricing.price,
              "grid-rows-[1fr_auto]": !pricing.oldPrice && !pricing.price,
              "border-primary shadow-lg scale-105": index === 1,
              "last:bg-gradient-to-br last:from-primary/5 last:to-secondary/5":
                index === 2,
            },
          ]}
        >
          {index === 1 && (
            <div class="absolute top-0 right-0 bg-primary text-background text-xs font-bold px-4 py-2 rounded-bl-xl uppercase tracking-wide">
              {t("popular")}
            </div>
          )}

          {(pricing.oldPrice || pricing.price) && (
            <header class="flex flex-col pb-6 border-b border-border">
              {pricing.oldPrice && (
                <span class="line-through text-sm text-muted-foreground">
                  {pricing.oldPrice}€
                </span>
              )}
              {pricing.price && (
                <div class="flex items-baseline gap-1">
                  <span class="text-4xl font-bold">{pricing.price}€</span>
                  <span class="text-sm text-muted-foreground">/ proyecto</span>
                </div>
              )}
            </header>
          )}
          <div class="flex flex-col gap-6 py-6">
            <div>
              <h3 class="text-2xl font-bold mb-2">{t(pricing.title)}</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">
                {t(pricing.description)}
              </p>
            </div>
            <ul class="flex flex-col gap-3">
              {pricing.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm">
                  <svg
                    class="w-5 h-5 text-primary flex-shrink-0 mt-0.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  <span class="leading-relaxed">{t(feature)}</span>
                </li>
              ))}
            </ul>
          </div>
          <footer class="flex gap-2 items-center pt-4">
            <button
              type="button"
              data-service-id={pricing.id}
              class="pricing-cta w-full text-center rounded-full bg-primary px-6 py-3 text-background font-semibold hover:brightness-95 active:scale-[0.98] transition-all shadow-sm hover:shadow-md"
            >
              {t(pricing.cta)}
            </button>
          </footer>
        </li>
      ))
    }
  </ul>
</section>

<script>
  // Manejar clicks en los CTAs de pricing
  function handlePricingClick(e: Event) {
    const button = e.currentTarget as HTMLButtonElement;
    const serviceId = button.dataset.serviceId;

    if (!serviceId) return;

    console.log("Pricing button clicked:", serviceId);

    // Actualizar la URL con el parámetro de servicio
    const url = new URL(window.location.href);
    url.searchParams.set("service", serviceId);
    window.history.replaceState({}, "", url.toString());

    console.log("URL updated:", url.toString());

    // Disparar evento para que el formulario se actualice
    window.dispatchEvent(new Event("popstate"));

    // Hacer scroll al formulario de contact con un pequeño delay
    requestAnimationFrame(() => {
      const contactSection = document.getElementById("contact");
      console.log("Contact section found:", contactSection);

      if (contactSection) {
        const yOffset = -80; // Offset para navbar si existe
        const y =
          contactSection.getBoundingClientRect().top +
          window.pageYOffset +
          yOffset;

        window.scrollTo({
          top: y,
          behavior: "smooth",
        });
      }
    });
  }

  function initPricingCTAs() {
    const pricingCTAs =
      document.querySelectorAll<HTMLButtonElement>(".pricing-cta");
    console.log("Initializing pricing CTAs:", pricingCTAs.length);

    pricingCTAs.forEach((cta) => {
      // Remover listener anterior si existe
      cta.removeEventListener("click", handlePricingClick);
      // Añadir nuevo listener
      cta.addEventListener("click", handlePricingClick);
    });
  }

  // Ejecutar cuando el DOM esté listo
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initPricingCTAs);
  } else {
    initPricingCTAs();
  }

  // Re-inicializar después de navegación (para Astro View Transitions)
  document.addEventListener("astro:page-load", initPricingCTAs);
</script>
