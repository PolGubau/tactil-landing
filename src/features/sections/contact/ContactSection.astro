---
import { useT } from "~/shared/i18n/fn";
import ContactForm from "./ContactForm";

const t = useT(Astro.currentLocale);

const translations = {
  name_label: t("contact_name_label"),
  name_placeholder: t("contact_name_placeholder"),
  email_label: t("contact_email_label"),
  email_placeholder: t("contact_email_placeholder"),
  phone_label: t("contact_phone_label"),
  phone_placeholder: t("contact_phone_placeholder"),
  service_label: t("contact_service_label"),
  service_placeholder: t("contact_service_placeholder"),
  service_web: t("contact_service_web"),
  service_landing: t("contact_service_landing"),
  service_ecommerce: t("contact_service_ecommerce"),
  service_app: t("contact_service_app"),
  service_other: t("contact_service_other"),
  message_label: t("contact_message_label"),
  message_placeholder: t("contact_message_placeholder"),
  submit: t("contact_submit"),
  sending: t("contact_sending"),
  success: t("contact_success"),
  error: t("contact_error"),
};
---

<section
  id="contacto"
  class="flex flex-col gap-16 py-24 w-full max-w-7xl mx-auto px-4"
>
  <header class="flex flex-col gap-4 text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight">
      {t("contact_title")}
    </h2>
    <p
      class="text-base md:text-lg text-muted-foreground max-w-2xl mx-auto leading-relaxed"
    >
      {t("contact_subtitle")}
    </p>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
    <!-- Left side - Professional info -->
    <div class="flex flex-col gap-8 lg:sticky lg:top-32">
      <div class="bg-muted/50 rounded-2xl p-8 md:p-10 border border-border">
        <h3 class="text-xl font-semibold mb-6">{t("contact_why_title")}</h3>
        <ul class="flex flex-col gap-6">
          <li class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1"
            >
              <svg
                class="w-5 h-5 text-primary"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <div>
              <strong class="block text-base mb-1"
                >{t("contact_why_1_title")}</strong
              >
              <span class="text-sm text-muted-foreground leading-relaxed"
                >{t("contact_why_1_desc")}</span
              >
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1"
            >
              <svg
                class="w-5 h-5 text-primary"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
                ></path>
              </svg>
            </div>
            <div>
              <strong class="block text-base mb-1"
                >{t("contact_why_2_title")}</strong
              >
              <span class="text-sm text-muted-foreground leading-relaxed"
                >{t("contact_why_2_desc")}</span
              >
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1"
            >
              <svg
                class="w-5 h-5 text-primary"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
                ></path>
              </svg>
            </div>
            <div>
              <strong class="block text-base mb-1"
                >{t("contact_why_3_title")}</strong
              >
              <span class="text-sm text-muted-foreground leading-relaxed"
                >{t("contact_why_3_desc")}</span
              >
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1"
            >
              <svg
                class="w-5 h-5 text-primary"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <strong class="block text-base mb-1"
                >{t("contact_why_4_title")}</strong
              >
              <span class="text-sm text-muted-foreground leading-relaxed"
                >{t("contact_why_4_desc")}</span
              >
            </div>
          </li>
        </ul>
      </div>

      <!-- Contact info -->
      <div
        class="flex flex-col gap-4 p-6 bg-muted/30 rounded-xl border border-border"
      >
        <h4
          class="font-semibold text-sm uppercase tracking-wide text-muted-foreground"
        >
          {t("contact_other_ways")}
        </h4>
        <div class="flex flex-col gap-3">
          <a
            href="mailto:gubaupol@gmail.com"
            class="flex items-center gap-3 text-sm hover:text-primary transition-colors group"
          >
            <svg
              class="w-5 h-5 text-muted-foreground group-hover:text-primary transition-colors"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <span class="font-medium">gubaupol@gmail.com</span>
          </a>
          <a
            href="https://www.linkedin.com/in/polgubauamores/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 text-sm hover:text-primary transition-colors group"
          >
            <svg
              class="w-5 h-5 text-muted-foreground group-hover:text-primary transition-colors"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              ></path>
            </svg>
            <span class="font-medium">LinkedIn</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Right side - Form -->
    <div
      class="bg-background border border-border rounded-2xl p-8 md:p-10 shadow-lg"
    >
      <ContactForm client:load translations={translations} />
    </div>
  </div>
</section>
