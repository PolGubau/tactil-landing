---
/**
 * Textarea Component - Primitive UI component for text areas
 */

import { inputBaseStyles, labelStyles } from "./styles";

type Props = {
	label?: string;
	id: string;
	name: string;
	placeholder?: string;
	required?: boolean;
	rows?: number;
	class?: string;
	labelClass?: string;
	// biome-ignore lint/suspicious/noExplicitAny: Allow other HTML attributes
	[key: string]: any;
};

const {
	label,
	id,
	name,
	placeholder,
	required = false,
	rows = 5,
	class: className = "",
	labelClass = "",
	...rest
} = Astro.props;

const textareaClasses = [inputBaseStyles, "resize-none", className]
	.filter(Boolean)
	.join(" ");
const labelClasses = [labelStyles, labelClass].filter(Boolean).join(" ");
---

<div class="flex flex-col gap-2">
	{
		label && (
			<label for={id} class={labelClasses}>
				{label}
				{required && <span class="text-red-500">*</span>}
			</label>
		)
	}
	<textarea
		id={id}
		name={name}
		placeholder={placeholder}
		required={required}
		rows={rows}
		class={textareaClasses}
		{...rest}></textarea>
</div>

