---
import { t } from "~/i18n/translations/fn";
import { T, type TranslationKey } from "~/i18n/translations/types";
import { getMetadata } from "~/lib/constants";
const l = Astro.currentLocale;
const defaultLink = getMetadata(l).getInTouchLink;

type Props = {
  label?: TranslationKey;
  href?: string;
};

const { label = T.getInTouch, href = defaultLink } = Astro.props;

export const ctaStyles = "bg-primary py-2 px-4 rounded-full cursor-crosshair hover:brightness-90 hover:scale-105 transition-all border-background border-2 hover:border-primary";
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class={ctaStyles}
  >{t(l, label)}
</a>
