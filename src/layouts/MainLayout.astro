---
import Navbar from "~/components/Layout/navbar/Navbar.astro";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Layout/footer/footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<html lang="en" dir="ltr" class={"w-screen overflow-x-hidden"}>
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body>
    <main class="flex min-h-screen w-full flex-col gap-20 bg-primary">
      <Navbar />
      <div class="bg-background rounded-b-[5vw]">
        <div
          class="items-center flex-col mx-auto gap-20 max-w-7xl px-6 xl:px-10 pb-[5vw]"
        >
          <slot />
        </div>
      </div>
      <Footer />
    </main>
  </body>
</html>

<style is:global>
  @keyframes opacity-fade {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    20% {
      opacity: 0;
      filter: blur(10px);
      pointer-events: none;
      transform: translateY(0);
    }

    to {
      transform: translateY(-100vh);
    }
  }

  .delayed-appearing {
    opacity: 0;
    animation: fade-in 0.8s ease-in-out;
    animation-delay: 2.2s;
    animation-fill-mode: forwards;
  }
</style>
